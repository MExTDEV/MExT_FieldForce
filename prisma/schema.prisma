  activity         String                     @db.Text
  scores           String                     @db.LongText
  remarks          String                     @db.Text
  deletedAt        DateTime?
  coachingDetail   CoachingDetail             @relation(fields: [coachingDetailId], references: [id], onDelete: Cascade)
  scoreRows        CoachingAppointmentScore[]

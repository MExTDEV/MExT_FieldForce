  @@index([appointmentExternalId])
}

model ErpOutboxDependency {
  id                 String           @id @default(cuid())
  commandId          String
  dependsOnCommandId String
  command            ErpOutboxCommand @relation("ErpOutboxDependencyCommand", fields: [commandId], references: [commandId], onDelete: Cascade)
  dependsOnCommand   ErpOutboxCommand @relation("ErpOutboxDependencyTarget", fields: [dependsOnCommandId], references: [commandId], onDelete: Restrict)
  createdAt          DateTime         @default(now())

  @@unique([commandId, dependsOnCommandId])
  @@index([dependsOnCommandId])
}

model ErpReplicaCheckpoint {
  id                  String                 @id @default(cuid())
  provider            ErpIntegrationProvider
  streamKey           String
  scopeKey            String
  schemaVersion       String
  cursor              String                 @db.LongText
  sourceCheckpoint    String?                @db.LongText
  lastSuccessfulSyncAt DateTime
  lastEventOccurredAt DateTime?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@unique([provider, streamKey, scopeKey])
  @@index([provider, lastSuccessfulSyncAt])
}

model ErpReconciliationIncident {
  id               String                          @id @default(cuid())
  provider         ErpIntegrationProvider
  type             ErpReconciliationIncidentType
  status           ErpReconciliationIncidentStatus @default(OPEN)
  deduplicationKey String
  commandId        String?
  entityType       String?
  entityExternalId String?
  summary          String                          @db.Text
  detailsJson      String?                         @db.LongText
  occurrenceCount  Int                             @default(1)
  firstDetectedAt  DateTime                        @default(now())
  lastDetectedAt   DateTime                        @default(now())
  resolvedAt       DateTime?
  resolvedByUserId String?
  resolutionNote   String?                         @db.Text
  command          ErpOutboxCommand?               @relation(fields: [commandId], references: [commandId], onDelete: SetNull)
  createdAt        DateTime                        @default(now())
  updatedAt        DateTime                        @updatedAt

  @@unique([provider, deduplicationKey])
  @@index([status, type, lastDetectedAt])
  @@index([commandId])
  @@index([entityType, entityExternalId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  entityType String
  entityId   String
  action     String
  oldValue   String?  @db.LongText
  newValue   String?  @db.LongText
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

model AppModule {
  id        String   @id @default(cuid())
  code      String   @unique
  naam      String
  actief    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_modules")
}

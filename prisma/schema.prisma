model ActionPoint {
  id               String                  @id @default(cuid())
  representativeId String
  interventionId   String?
  ownerId          String
  title            String
  description      String
  type             ActionPointType
  status           ActionPointStatus       @default(NIEUW)
  priority         Priority                @default(NORMAL)
  kpiDefinitionId  String?
  startValue       Decimal?                @db.Decimal(14, 2)
  targetValue      Decimal?                @db.Decimal(14, 2)
  currentValue     Decimal?                @db.Decimal(14, 2)
  dueDate          DateTime?
  closedAt         DateTime?
  closedByUserId   String?
  representative   User                    @relation("RepresentativeActions", fields: [representativeId], references: [id])
  intervention     Intervention?           @relation(fields: [interventionId], references: [id], onDelete: SetNull)
  owner            User                    @relation("OwnedActions", fields: [ownerId], references: [id])
  closedBy         User?                   @relation("ClosedActionPoints", fields: [closedByUserId], references: [id], onDelete: SetNull)
  kpiDefinition    KpiDefinition?          @relation(fields: [kpiDefinitionId], references: [id])
  assignments      ActionPointAssignment[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([representativeId, status])
  @@index([ownerId])
  @@index([dueDate])
  @@index([status, dueDate])
  @@index([closedAt])
  @@index([closedByUserId])
  @@index([representativeId, updatedAt])
}

model ActionPointAssignment {
  id               String      @id @default(cuid())
  actionPointId    String
  representativeId String
  scope            String      @default("individual")
  status           ActionPointStatus @default(OPEN)
  closedAt         DateTime?
  closedByUserId   String?
  actionPoint      ActionPoint @relation(fields: [actionPointId], references: [id], onDelete: Cascade)
  representative   User        @relation(fields: [representativeId], references: [id], onDelete: Cascade)
  closedBy         User?       @relation("ClosedActionPointAssignments", fields: [closedByUserId], references: [id], onDelete: SetNull)

  @@unique([actionPointId, representativeId])
  @@index([representativeId])
  @@index([status, closedAt])
  @@index([closedByUserId])
}

model ActionDefinition {
  id              String                 @id @default(cuid())
  title           String
  description     String                 @db.Text
  tipsAndTricks   String                 @db.LongText
  targetTypeId    String?                @map("target_type_id")
  targetValue     Decimal?               @db.Decimal(14, 2)
  priority        Priority               @default(NORMAL)
  scope           ActionScope            @default(GLOBAL)
  scopeKey        String
  country         Country?
  teamId          String?
  userId          String?
  active          Boolean                @default(true)
  validFrom       DateTime
  validUntil      DateTime?
  deletedAt       DateTime?
  createdById     String
  updatedById     String
  team            Team?                  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user            User?                  @relation("ActionDefinitionUser", fields: [userId], references: [id], onDelete: Cascade)
  targetType      ActionPointTargetType? @relation(fields: [targetTypeId], references: [id])
  createdBy       User                   @relation("ActionDefinitionCreatedBy", fields: [createdById], references: [id])
  updatedBy       User                   @relation("ActionDefinitionUpdatedBy", fields: [updatedById], references: [id])
  products        ActionDefinitionProduct[]
  targetOverrides ActionTargetOverride[]
  coachingActions CoachingAction[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  @@index([scope, scopeKey, active])
  @@index([validFrom, validUntil])
  @@index([country])
  @@index([teamId])
  @@index([userId])
  @@index([targetTypeId])
}

model ActionPointTargetType {
  id                String             @id @default(cuid())
  code              ActionScope         @unique
  name              String
  description       String?            @db.Text
  isActive          Boolean            @default(true) @map("is_active")
  sortOrder         Int                @default(0) @map("sort_order")
  actionDefinitions ActionDefinition[]
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("action_point_target_types")
}

model ActionDefinitionProduct {
  id                 String           @id @default(cuid())
  actionDefinitionId String           @map("action_point_id")
  productId          String           @map("product_id")
  actionDefinition   ActionDefinition @relation(fields: [actionDefinitionId], references: [id], onDelete: Cascade)
  product            Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt          DateTime         @default(now()) @map("created_at")

  @@unique([actionDefinitionId, productId])
  @@index([productId])
  @@map("action_point_products")
}

model ActionTargetOverride {

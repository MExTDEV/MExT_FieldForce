generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  REPRESENTATIVE
  SALES_LEADER
  COUNTRY_MANAGER
  GROUP_MANAGER
  ADMIN
  SUPER_ADMIN
}

enum Country {
  BE
  NL
  DE
}

enum Language {
  nl
  fr
  de
}

enum TeamLeaderType {
  PRIMARY
  EXTRA
}

enum InterventionType {
  BEGELEIDING
  CONTACTMOMENT
  RETRAINING
  SALES_TRAINING
  HULPAANVRAAG
}

enum InterventionStatus {
  CONCEPT
  GEPLAND
  IN_UITVOERING
  WACHT_OP_VT_INPUT
  WACHT_OP_VT
  WACHT_OP_AKKOORD
  AFGESLOTEN
  GEANNULEERD
}

enum ActionPointType {
  KPI
  VAARDIGHEID
  GEDRAG
}

enum ActionPointStatus {
  NIEUW
  IN_UITVOERING
  BEHAALD
  NIET_BEHAALD
  GEANNULEERD
}

enum Priority {
  LOW
  NORMAL
  HIGH
}

enum ReflectionStatus {
  NIET_GESTART
  INGEDIEND
}

enum ApprovalStatus {
  GELEZEN_AKKOORD
  GELEZEN_NIET_AKKOORD
}

enum HelpRequestStatus {
  NIEUW
  IN_BEHANDELING
  VERVOLGACTIE_GEPLAND
  AFGESLOTEN
  GEANNULEERD
}

model User {
  id                 String          @id @default(cuid())
  firstName          String
  lastName           String
  email              String          @unique
  entraId            String?         @unique
  role               Role
  country            Country
  language           Language        @default(nl)
  active             Boolean         @default(true)
  teamId             String?
  levelId            String?
  team               Team?           @relation("TeamMembers", fields: [teamId], references: [id])
  level              Level?          @relation(fields: [levelId], references: [id])
  primaryTeams       Team[]          @relation("PrimaryLeader")
  teamLeaderships    TeamLeader[]
  representedItems   Intervention[]  @relation("RepresentativeInterventions")
  initiatedItems     Intervention[]  @relation("InitiatedInterventions")
  ownedItems         Intervention[]  @relation("OwnedInterventions")
  kpiSnapshots       KpiSnapshot[]
  actionPoints       ActionPoint[]   @relation("RepresentativeActions")
  ownedActionPoints  ActionPoint[]   @relation("OwnedActions")
  reflections        Reflection[]
  approvals          Approval[]
  requestedHelp      HelpRequest[]   @relation("HelpRequester")
  receivedHelp       HelpRequest[]   @relation("HelpRepresentative")
  productAnalyses    ProductAnalysis[]
  auditLogs          AuditLog[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([country, role])
  @@index([teamId])
}

model Team {
  id              String       @id @default(cuid())
  name            String
  country         Country
  primaryLeaderId String
  active          Boolean      @default(true)
  primaryLeader   User         @relation("PrimaryLeader", fields: [primaryLeaderId], references: [id])
  members         User[]       @relation("TeamMembers")
  leaders         TeamLeader[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([country, name])
}

model TeamLeader {
  id        String         @id @default(cuid())
  teamId    String
  userId    String
  type      TeamLeaderType
  team      Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model Level {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  color       String
  active      Boolean  @default(true)
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model KpiDefinition {
  id           String          @id @default(cuid())
  code         String          @unique
  name         String
  description  String
  country      Country?
  active       Boolean         @default(true)
  unit         String
  snapshots    KpiSnapshot[]
  actionPoints ActionPoint[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model KpiSnapshot {
  id              String        @id @default(cuid())
  userId          String
  kpiDefinitionId String
  periodStart     DateTime
  periodEnd       DateTime
  value           Decimal       @db.Decimal(14, 2)
  target          Decimal?      @db.Decimal(14, 2)
  source          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  kpiDefinition   KpiDefinition @relation(fields: [kpiDefinitionId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@unique([userId, kpiDefinitionId, periodStart, periodEnd])
}

model Intervention {
  id               String             @id @default(cuid())
  type             InterventionType
  status           InterventionStatus @default(CONCEPT)
  representativeId String
  initiatorId      String
  ownerId          String
  country          Country
  title            String
  description      String?
  plannedAt        DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  representative   User               @relation("RepresentativeInterventions", fields: [representativeId], references: [id])
  initiator        User               @relation("InitiatedInterventions", fields: [initiatorId], references: [id])
  owner            User               @relation("OwnedInterventions", fields: [ownerId], references: [id])
  focuses          InterventionFocus[]
  scores           Score[]
  actionPoints     ActionPoint[]
  reflection       Reflection?
  approval         Approval?
  helpRequest      HelpRequest?
  contactMoment    ContactMomentDetail?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([representativeId, type])
  @@index([country, status])
}

model ContactMomentDetail {
  id                   String       @id @default(cuid())
  interventionId       String       @unique
  reason               String
  reportedProblems     String?
  leaderThemes         Json
  representativeKpis   Json
  representativeThemes Json
  discussedThemes      Json
  conclusion           String?
  sourceHelpRequestId  String?
  intervention         Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
}

model CoachingFocus {
  id            String              @id @default(cuid())
  code          String              @unique
  name          String
  active        Boolean             @default(true)
  sortOrder     Int
  criteria      CoachingCriterion[]
  interventions InterventionFocus[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model CoachingCriterion {
  id        String        @id @default(cuid())
  focusId   String
  name      String
  active    Boolean       @default(true)
  sortOrder Int
  focus     CoachingFocus @relation(fields: [focusId], references: [id], onDelete: Cascade)
  scores    Score[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([focusId, name])
}

model InterventionFocus {
  id             String        @id @default(cuid())
  interventionId String
  focusId        String
  intervention   Intervention  @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  focus          CoachingFocus @relation(fields: [focusId], references: [id])

  @@unique([interventionId, focusId])
}

model Score {
  id             String            @id @default(cuid())
  interventionId String
  criterionId    String
  score          Int?
  notApplicable  Boolean           @default(false)
  comment        String?
  previousScore  Int?
  intervention   Intervention      @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  criterion      CoachingCriterion @relation(fields: [criterionId], references: [id])

  @@unique([interventionId, criterionId])
}

model ActionPoint {
  id              String            @id @default(cuid())
  representativeId String
  interventionId  String?
  ownerId          String
  title            String
  description      String
  type             ActionPointType
  status           ActionPointStatus @default(NIEUW)
  priority         Priority          @default(NORMAL)
  kpiDefinitionId  String?
  startValue       Decimal?          @db.Decimal(14, 2)
  targetValue      Decimal?          @db.Decimal(14, 2)
  currentValue     Decimal?          @db.Decimal(14, 2)
  dueDate          DateTime?
  representative   User              @relation("RepresentativeActions", fields: [representativeId], references: [id])
  intervention     Intervention?     @relation(fields: [interventionId], references: [id], onDelete: SetNull)
  owner            User              @relation("OwnedActions", fields: [ownerId], references: [id])
  kpiDefinition    KpiDefinition?    @relation(fields: [kpiDefinitionId], references: [id])
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([representativeId, status])
}

model Reflection {
  id               String           @id @default(cuid())
  interventionId   String           @unique
  representativeId String
  learnedText      String
  workOnText       String
  concreteGoalText String
  status           ReflectionStatus @default(NIET_GESTART)
  submittedAt      DateTime?
  intervention     Intervention     @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  representative   User             @relation(fields: [representativeId], references: [id])
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model Approval {
  id               String         @id @default(cuid())
  interventionId   String         @unique
  representativeId String
  status           ApprovalStatus
  comment          String?
  openedAt         DateTime?
  confirmedAt      DateTime?
  intervention     Intervention   @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  representative   User           @relation(fields: [representativeId], references: [id])
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model HelpRequest {
  id               String            @id @default(cuid())
  interventionId   String?           @unique
  requesterId      String
  representativeId String
  subject          String
  difficulty       String
  desiredResult    String
  explanation      String?
  urgency          Priority
  status           HelpRequestStatus @default(NIEUW)
  followUpType     InterventionType?
  intervention     Intervention?     @relation(fields: [interventionId], references: [id], onDelete: SetNull)
  requester        User              @relation("HelpRequester", fields: [requesterId], references: [id])
  representative   User              @relation("HelpRepresentative", fields: [representativeId], references: [id])
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Product {
  id       String            @id @default(cuid())
  name     String            @unique
  sortOrder Int
  active   Boolean           @default(true)
  analyses ProductAnalysis[]
}

model ProductAnalysis {
  id                    String  @id @default(cuid())
  representativeId      String
  productId             String
  purchaseStatus        String
  afwijkendeHoeveelheid Decimal? @db.Decimal(14, 2)
  lastPurchaseYears     Int?
  representative        User    @relation(fields: [representativeId], references: [id], onDelete: Cascade)
  product               Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([representativeId, productId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  entityType String
  entityId   String
  action     String
  oldValue   Json?
  newValue   Json?
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

model AppModule {
  id        String   @id @default(cuid())
  code      String   @unique
  naam      String
  actief    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_modules")
}

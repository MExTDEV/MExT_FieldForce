generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  REPRESENTATIVE
  SALES_LEADER
  SALES_MANAGER
  SERVICE_OPERATOR
  COUNTRY_MANAGER
  GROUP_MANAGER
  ADMIN
  SUPER_ADMIN
}

enum Country {
  BE
  NL
  DE
}

enum Language {
  nl
  fr
  de
}

enum TeamLeaderType {
  PRIMARY
  EXTRA
}

enum RepresentativeLevel {
  STARTER
  SALES_EXECUTIVE
  PROFESSIONAL
  EXPERT
}

enum InterventionType {
  BEGELEIDING
  CONTACTMOMENT
  RETRAINING
  SALES_TRAINING
  HULPAANVRAAG
}

enum InterventionStatus {
  CONCEPT
  GEPLAND
  IN_UITVOERING
  WACHT_OP_VT_INPUT
  WACHT_OP_VT
  WACHT_OP_AKKOORD
  GEFINALISEERD
  AFGESLOTEN
  GESLOTEN
  VOLTOOID
  VERZONDEN_TER_AKKOORD
  AKKOORD_DOOR_VERTEGENWOORDIGER
  GEANNULEERD
  NIET_UITGEVOERD
}

enum ActionPointType {
  KPI
  VAARDIGHEID
  GEDRAG
}

enum ActionPointStatus {
  OPEN
  NIEUW
  IN_UITVOERING
  AFGEROND
  BEHAALD
  NIET_BEHAALD
  GEANNULEERD
}

enum CoachingActionReviewStatus {
  PROPOSED
  APPROVED
  REJECTED
  ACTIVE
}

enum Priority {
  LOW
  NORMAL
  HIGH
}

enum KpiEvaluationDirection {
  HIGHER_IS_BETTER
  LOWER_IS_BETTER
  TARGET
}

enum KpiTargetScope {
  GLOBAL
  COUNTRY
  TEAM
  USER
  ROLE
}

enum CriterionType {
  KPI
  COAT_RACK
  GENERAL_EVALUATION
  PERSONALITY
  GENERAL_COACHING_SCORE
}

enum CriterionScopeType {
  GLOBAL
  COUNTRY
  TEAM
  USER
}

enum KpiValueType {
  NUMBER
  DECIMAL
  CURRENCY
  BOOLEAN
  SCORE
}

enum KpiPeriodType {
  DAY
  WEEK
  MONTH
  QUARTER
  YEAR
  CUSTOM
}

enum ActionScope {
  GLOBAL
  COUNTRY
  TEAM
  USER
}

enum ReflectionStatus {
  NIET_GESTART
  INGEDIEND
}

enum ApprovalStatus {
  GELEZEN_AKKOORD
  GELEZEN_NIET_AKKOORD
}

enum HelpRequestStatus {
  NIEUW
  OPEN
  IN_BEHANDELING
  VERVOLGACTIE_GEPLAND
  BEGELEIDING
  CONTACTMOMENT
  RETRAINING
  SALESTRAINING
  GESLOTEN
  INGETROKKEN
  AFGESLOTEN
  GEANNULEERD
}

enum UserProfilePhotoSyncStatus {
  SYNCED
  NO_PHOTO
  SKIPPED
  ERROR
}

enum ProfilePhotoSyncRunStatus {
  QUEUED
  RUNNING
  COMPLETED
  PARTIAL_ERROR
  ERROR
  SKIPPED
}

enum ProfilePhotoSyncTrigger {
  NIGHTLY
  MANUAL
}

enum StarterEvaluationMoment {
  MONTH_1_5
  MONTH_3
  MONTH_5
}

enum StarterEvaluationStatus {
  DUE
  PREPARATION
  READY_FOR_CONVERSATION
  IN_PROGRESS
  WAITING_FOR_APPROVAL
  NOT_AGREED
  APPROVED
  CANCELLED
}

enum StarterEvaluationAnswerType {
  SHORT_TEXT
  RICH_TEXT
  BOOLEAN
  NUMBER
  PERCENTAGE
  CURRENCY
  SCORE
  CHOICE
  MULTI_CHOICE
  DATE
  SYSTEM
  LINKED_CRITERION
  ACTION_POINTS
}

enum StarterEvaluationAssignee {
  REPRESENTATIVE
  EVALUATOR
  BOTH_SEPARATE
  SYSTEM
  SHARED_EVALUATOR
}

enum StarterEvaluationAnswerRole {
  REPRESENTATIVE
  EVALUATOR
  SYSTEM
}

enum ContractCalculationStatus {
  DRAFT
  SIGNED
}

enum ContractModelStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum ContractImportStatus {
  VALIDATING
  PREVIEW_READY
  IMPORTED
  FAILED
  CANCELLED
}

enum ContractLetterTemplateStatus {
  DRAFT
  ACTIVE
  INACTIVE
  FAILED
}

enum ErpIntegrationProvider {
  MOCK
  BC_NAV
  ODOO
}

enum ErpInboxStatus {
  RECEIVED
  PROCESSING
  APPLIED
  RETRYABLE
  FAILED
}

enum ErpOutboxStatus {
  PENDING
  PROCESSING
  ACCEPTED
  REJECTED
  RETRYABLE
}

enum ErpReconciliationIncidentType {
  COMMAND_UNKNOWN
  ACKNOWLEDGEMENT_MISMATCH
  EVENT_PAYLOAD_CONFLICT
  EVENT_APPLY_FAILED
  CHECKPOINT_INVALID
  PERMISSION_REVOKED
  AUTHORIZATION_ERROR
  DEPENDENCY_REJECTED
  REPEATED_FAILURE
  PROVIDER_ERROR
}

enum ErpReconciliationIncidentStatus {
  OPEN
  RESOLVED
  IGNORED
}

enum DevicePlatform {
  WINDOWS
  ANDROID
}

enum DeviceRegistrationStatus {
  ACTIVE
  REVOKED
}

enum DeviceControlCommandType {
  LOGOUT
  WIPE
}

enum DeviceControlCommandStatus {
  PENDING
  DELIVERED
  ACKNOWLEDGED
}

enum SalesDayFeatureKey {
  SALESDAY
  INVENTORY
  OFFLINE_COMMANDS
  ERP_WRITES
}

enum SalesDayFeatureScope {
  GLOBAL
  COUNTRY
  TEAM
  USER
}

model User {
  id                       String                      @id @default(cuid())
  firstName                String
  lastName                 String
  email                    String                      @unique
  mobile                   String?
  avatarUrl                String?
  profilePhotoStorageKey   String?
  profilePhotoMimeType     String?
  profilePhotoHash         String?
  profilePhotoSyncedAt     DateTime?
  profilePhotoSyncStatus   UserProfilePhotoSyncStatus?
  profilePhotoSyncError    String?                     @db.Text
  branchNumber             String?
  representativeId         String?                     @unique
  entraId                  String?                     @unique
  microsoftEmail           String?
  lastLoginAt              DateTime?
  passwordHash             String?
  role                     Role
  country                  Country
  language                 Language                    @default(nl)
  active                   Boolean                     @default(true)
  representativeLevel      RepresentativeLevel         @default(STARTER)
  starterStartDate         DateTime?                   @db.Date
  teamSupervisor           Boolean                     @default(false)
  teamId                   String?
  levelId                  String?
  team                     Team?                       @relation("TeamMembers", fields: [teamId], references: [id])
  level                    Level?                      @relation(fields: [levelId], references: [id])
  primaryTeams             Team[]                      @relation("PrimaryLeader")
  teamLeaderships          TeamLeader[]
  representedItems         Intervention[]              @relation("RepresentativeInterventions")
  initiatedItems           Intervention[]              @relation("InitiatedInterventions")
  ownedItems               Intervention[]              @relation("OwnedInterventions")
  kpiSnapshots             KpiSnapshot[]
  kpiTargetOverrides       KpiTargetOverride[]
  scopedKpiDefinitions     KpiDefinition[]             @relation("KpiDefinitionUser")
  createdKpiDefinitions    KpiDefinition[]             @relation("KpiDefinitionCreatedBy")
  updatedKpiDefinitions    KpiDefinition[]             @relation("KpiDefinitionUpdatedBy")
  kpiTargets               KpiTarget[]                 @relation("KpiTargetUser")
  createdKpiTargets        KpiTarget[]                 @relation("KpiTargetCreatedBy")
  updatedKpiTargets        KpiTarget[]                 @relation("KpiTargetUpdatedBy")
  actionPoints             ActionPoint[]               @relation("RepresentativeActions")
  ownedActionPoints        ActionPoint[]               @relation("OwnedActions")
  closedActionPoints       ActionPoint[]               @relation("ClosedActionPoints")
  reflections              Reflection[]
  approvals                Approval[]
  requestedHelp            HelpRequest[]               @relation("HelpRequester")
  receivedHelp             HelpRequest[]               @relation("HelpRepresentative")
  responsibleHelpRequests   HelpRequest[]               @relation("HelpResponsible")
  helpRequestAnswers        HelpRequestAnswer[]         @relation("HelpAnswerAuthor")
  productAnalyses          ProductAnalysis[]
  auditLogs                AuditLog[]
  microsoftAuthToken       MicrosoftAuthToken?
  createdCriteria          PersonalCoachingCriterion[] @relation("CreatedPersonalCriteria")
  representativeCriteria   PersonalCoachingCriterion[] @relation("RepresentativePersonalCriteria")
  permissions              UserPermission[]
  loginAliases             UserLoginAlias[]
  loginSessions            UserLoginSession[]
  trainingParticipants     TrainingParticipant[]
  actionAssignments        ActionPointAssignment[]
  closedActionAssignments  ActionPointAssignment[]      @relation("ClosedActionPointAssignments")
  interventionParticipants InterventionParticipant[]
  scopedActionDefinitions   ActionDefinition[]        @relation("ActionDefinitionUser")
  createdActionDefinitions  ActionDefinition[]        @relation("ActionDefinitionCreatedBy")
  updatedActionDefinitions  ActionDefinition[]        @relation("ActionDefinitionUpdatedBy")
  actionTargetOverrides     ActionTargetOverride[]
  criterionScopeLinks       CriterionScopeLink[]      @relation("CriterionScopeLinkUser")
  coachingActions           CoachingAction[]
  coachingChangeLogs        CoachingChangeLog[]
  representativeLevelHistory RepresentativeLevelHistory[]
  starterEvaluations        StarterEvaluation[]       @relation("StarterEvaluationRepresentative")
  starterEvaluationLeader   StarterEvaluation[]       @relation("StarterEvaluationLeader")
  starterEvaluationCountryManager StarterEvaluation[] @relation("StarterEvaluationCountryManager")
  starterEvaluationCancelled StarterEvaluation[]      @relation("StarterEvaluationCancelledBy")
  starterEvaluationSentForApproval StarterEvaluation[] @relation("StarterEvaluationSentForApprovalBy")
  starterEvaluationApproved StarterEvaluation[]       @relation("StarterEvaluationApprovedBy")
  starterEvaluationManualStarted StarterEvaluation[]  @relation("StarterEvaluationManualStartedBy")
  starterEvaluationAnswers  StarterEvaluationAnswer[] @relation("StarterEvaluationAnswerUpdatedBy")
  starterEvaluationActions  StarterEvaluationDraftActionPoint[] @relation("StarterEvaluationDraftActionOwner")
  starterEvaluationQuestions StarterEvaluationQuestion[] @relation("StarterEvaluationQuestionUser")
  starterEvaluationQuestionScopeLinks StarterEvaluationQuestionScopeLink[] @relation("StarterEvaluationQuestionScopeLinkUser")
  starterEvaluationQuestionsCreated StarterEvaluationQuestion[] @relation("StarterEvaluationQuestionCreatedBy")
  starterEvaluationQuestionsUpdated StarterEvaluationQuestion[] @relation("StarterEvaluationQuestionUpdatedBy")
  countryAccess             UserCountryAccess[]
  contractCustomers         ContractCustomer[]         @relation("ContractCustomerOwner")
  contractCalculations      ContractCalculation[]      @relation("ContractCalculationOwner")
  contractModelVersionsActivated ContractModelVersion[] @relation("ContractModelVersionActivatedBy")
  contractModelVersionsImported ContractModelVersion[] @relation("ContractModelVersionImportedBy")
  contractImportRuns        ContractImportRun[]        @relation("ContractImportStartedBy")
  contractLetterTemplatesUploaded ContractLetterTemplate[] @relation("ContractLetterTemplateUploadedBy")
  contractLetterTemplatesActivated ContractLetterTemplate[] @relation("ContractLetterTemplateActivatedBy")
  contractGeneratedDocuments ContractGeneratedDocument[] @relation("ContractGeneratedDocumentGeneratedBy")
  erpOutboxCommands        ErpOutboxCommand[]          @relation("ErpOutboxCommandActor")
  registeredSalesDevices   DeviceRegistration[]        @relation("DeviceRegistrationOwner")
  revokedSalesDevices      DeviceRegistration[]        @relation("DeviceRegistrationRevokedBy")
  requestedDeviceControls  DeviceControlCommand[]      @relation("DeviceControlCommandRequestedBy")
  activatedSalesDayEmergencyModes SalesDayEmergencyMode[] @relation("SalesDayEmergencyModeActivatedBy")
  deactivatedSalesDayEmergencyModes SalesDayEmergencyMode[] @relation("SalesDayEmergencyModeDeactivatedBy")
  salesDayFeatureOverrides SalesDayFeatureFlag[] @relation("SalesDayFeatureTargetUser")
  updatedSalesDayFeatureFlags SalesDayFeatureFlag[] @relation("SalesDayFeatureUpdatedBy")
  createdAt                DateTime                    @default(now())
  updatedAt                DateTime                    @updatedAt

  @@index([country, role])
  @@index([teamId])
  @@index([role, representativeLevel])
  @@index([profilePhotoSyncStatus])
}

model ProfilePhotoSyncRun {
  id               String                    @id @default(cuid())
  trigger          ProfilePhotoSyncTrigger
  status           ProfilePhotoSyncRunStatus @default(QUEUED)
  startedByUserId  String?
  startedAt        DateTime?
  finishedAt       DateTime?
  checkedUsers     Int                       @default(0)
  updatedPhotos    Int                       @default(0)
  unchangedPhotos  Int                       @default(0)
  noPhotoUsers     Int                       @default(0)
  skippedUsers     Int                       @default(0)
  errorUsers       Int                       @default(0)
  errorMessage     String?                   @db.Text
  userErrorsJson   String?                   @db.LongText
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  @@index([status, createdAt])
  @@index([trigger, createdAt])
  @@index([startedByUserId])
}

model RepresentativeLevelHistory {
  id             String              @id @default(cuid())
  userId         String
  oldValue       RepresentativeLevel?
  newValue       RepresentativeLevel
  changedById    String?
  changedAt      DateTime            @default(now())
  reason         String?             @db.Text
  migrationKey   String?             @unique
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, changedAt])
  @@index([changedById])
}

model UserCountryAccess {
  id        String   @id @default(cuid())
  userId    String
  country   Country
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, country])
  @@index([country])
}

model MicrosoftAuthToken {
  id                    String   @id @default(cuid())
  userId                String   @unique
  accessTokenEncrypted  String   @db.LongText
  refreshTokenEncrypted String?  @db.LongText
  expiresAt             DateTime
  scopes                String   @db.VarChar(512)
  lastError             String?  @db.Text
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([expiresAt])
}

model UserLoginAlias {
  id        String   @id @default(cuid())
  userId    String
  email     String   @unique
  provider  String   @default("microsoft-entra-id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model UserLoginSession {
  id              String    @id @default(cuid())
  userId          String
  requestKey      String    @unique
  sessionId       String    @unique
  loginAt         DateTime  @default(now())
  logoutAt        DateTime?
  lastActivityAt  DateTime  @default(now())
  expiresAt       DateTime
  durationSeconds Int       @default(0)
  provider        String
  email           String?
  ipAddress       String?
  userAgent       String?   @db.Text
  browser         String?
  operatingSystem String?
  deviceType      String?
  deviceRegistrationId String?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceRegistration DeviceRegistration? @relation(fields: [deviceRegistrationId], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId, loginAt])
  @@index([userId, provider])
  @@index([userId, lastActivityAt])
  @@index([deviceRegistrationId, logoutAt])
}

model Team {
  id               String                      @id @default(cuid())
  name             String
  country          Country
  primaryLeaderId  String?
  active           Boolean                     @default(true)
  primaryLeader    User?                       @relation("PrimaryLeader", fields: [primaryLeaderId], references: [id], onDelete: SetNull)
  members          User[]                      @relation("TeamMembers")
  leaders          TeamLeader[]
  personalCriteria PersonalCoachingCriterion[]
  kpiTargetOverrides KpiTargetOverride[]
  kpiDefinitions     KpiDefinition[]             @relation("KpiDefinitionTeam")
  kpiTargets         KpiTarget[]                 @relation("KpiTargetTeam")
  actionDefinitions ActionDefinition[]
  actionTargetOverrides ActionTargetOverride[]
  criterionScopeLinks CriterionScopeLink[]       @relation("CriterionScopeLinkTeam")
  starterEvaluationQuestions StarterEvaluationQuestion[] @relation("StarterEvaluationQuestionTeam")
  starterEvaluationQuestionScopeLinks StarterEvaluationQuestionScopeLink[] @relation("StarterEvaluationQuestionScopeLinkTeam")
  contractCustomers ContractCustomer[]
  contractCalculations ContractCalculation[]
  salesDayFeatureFlags SalesDayFeatureFlag[]
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt

  @@unique([country, name])
}

model TeamLeader {
  id     String         @id @default(cuid())
  teamId String
  userId String
  type   TeamLeaderType
  team   Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  label       String
  group       String
  description String?          @db.Text
  roleGrants  RolePermission[]
  userGrants  UserPermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model RolePermission {
  id           String     @id @default(cuid())
  role         Role
  permissionId String
  enabled      Boolean    @default(true)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@index([permissionId])
}

model RoleConfiguration {
  id        String   @id @default(cuid())
  role      Role     @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
}

model UserPermission {
  id           String     @id @default(cuid())
  userId       String
  permissionId String
  enabled      Boolean
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([permissionId])
}

model Level {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  color       String
  active      Boolean  @default(true)
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model KpiDefinition {
  id                  String                 @id @default(cuid())
  code                String                 @unique
  name                String
  description         String
  categoryId          String?                @map("category_id")
  typeId              String?                @map("type_id")
  targetTypeId        String?                @map("target_type_id")
  country             Country?
  teamId              String?                @map("target_team_id")
  userId              String?                @map("target_user_id")
  targetRole          Role?                  @map("target_role")
  active              Boolean                @default(true)
  unit                String
  targetValue         Decimal                @default(0) @db.Decimal(14, 2)
  minValue            Decimal?               @db.Decimal(14, 2)
  maxValue            Decimal?               @db.Decimal(14, 2)
  weight              Decimal?               @db.Decimal(8, 2)
  countsForReporting  Boolean                @default(true) @map("counts_for_reporting")
  countsForPerformanceCircle Boolean         @default(true) @map("counts_for_performance_circle")
  includeInStarterEvaluations Boolean        @default(false) @map("include_in_starter_evaluations")
  sortOrder           Int                    @default(0) @map("sort_order")
  validFrom           DateTime               @default(now()) @map("valid_from")
  validUntil          DateTime?              @map("valid_until")
  createdById         String?                @map("created_by_user_id")
  updatedById         String?                @map("updated_by_user_id")
  evaluationDirection KpiEvaluationDirection @default(HIGHER_IS_BETTER)
  category            KpiCategory?           @relation(fields: [categoryId], references: [id])
  type                KpiType?               @relation(fields: [typeId], references: [id])
  targetType          KpiTargetType?         @relation(fields: [targetTypeId], references: [id])
  team                Team?                  @relation("KpiDefinitionTeam", fields: [teamId], references: [id], onDelete: Cascade)
  user                User?                  @relation("KpiDefinitionUser", fields: [userId], references: [id], onDelete: Cascade)
  createdBy           User?                  @relation("KpiDefinitionCreatedBy", fields: [createdById], references: [id])
  updatedBy           User?                  @relation("KpiDefinitionUpdatedBy", fields: [updatedById], references: [id])
  snapshots           KpiSnapshot[]
  actionPoints        ActionPoint[]
  targetOverrides     KpiTargetOverride[]
  targets             KpiTarget[]
  criterionScopeLinks CriterionScopeLink[]       @relation("CriterionScopeLinkKpi")
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@index([categoryId])
  @@index([typeId])
  @@index([targetTypeId])
  @@index([country])
  @@index([teamId])
  @@index([userId])
  @@index([active, sortOrder])
}

model KpiCategory {
  id             String          @id @default(cuid())
  code           String          @unique
  name           String
  description    String?         @db.Text
  isActive       Boolean         @default(true) @map("is_active")
  sortOrder      Int             @default(0) @map("sort_order")
  kpiDefinitions KpiDefinition[]
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("kpi_categories")
}

model KpiType {
  id             String          @id @default(cuid())
  code           String          @unique
  name           String
  description    String?         @db.Text
  valueType      KpiValueType    @map("value_type")
  isActive       Boolean         @default(true) @map("is_active")
  sortOrder      Int             @default(0) @map("sort_order")
  kpiDefinitions KpiDefinition[]
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("kpi_types")
}

model KpiTargetType {
  id             String          @id @default(cuid())
  code           KpiTargetScope  @unique
  name           String
  description    String?         @db.Text
  isActive       Boolean         @default(true) @map("is_active")
  sortOrder      Int             @default(0) @map("sort_order")
  kpiDefinitions KpiDefinition[]
  kpiTargets     KpiTarget[]
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("kpi_target_types")
}

model KpiTarget {
  id              String          @id @default(cuid())
  kpiDefinitionId String          @map("kpi_definition_id")
  targetTypeId    String          @map("target_type_id")
  scope           KpiTargetScope
  scopeKey        String          @map("scope_key")
  country         Country?
  teamId          String?         @map("team_id")
  userId          String?         @map("user_id")
  role            Role?
  periodType      KpiPeriodType   @map("period_type")
  periodStart     DateTime        @map("period_start")
  periodEnd       DateTime        @map("period_end")
  targetValue     Decimal         @db.Decimal(14, 2) @map("target_value")
  active          Boolean         @default(true)
  createdById     String?         @map("created_by_user_id")
  updatedById     String?         @map("updated_by_user_id")
  kpiDefinition   KpiDefinition   @relation(fields: [kpiDefinitionId], references: [id], onDelete: Cascade)
  targetType      KpiTargetType   @relation(fields: [targetTypeId], references: [id])
  team            Team?           @relation("KpiTargetTeam", fields: [teamId], references: [id], onDelete: Cascade)
  user            User?           @relation("KpiTargetUser", fields: [userId], references: [id], onDelete: Cascade)
  createdBy       User?           @relation("KpiTargetCreatedBy", fields: [createdById], references: [id])
  updatedBy       User?           @relation("KpiTargetUpdatedBy", fields: [updatedById], references: [id])
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@unique([kpiDefinitionId, scopeKey, periodType, periodStart, periodEnd])
  @@index([kpiDefinitionId, active])
  @@index([targetTypeId])
  @@index([scope, scopeKey])
  @@index([country])
  @@index([teamId])
  @@index([userId])
  @@index([role])
  @@index([periodStart, periodEnd])
  @@map("kpi_targets")
}

model KpiTargetOverride {
  id                  String                 @id @default(cuid())
  kpiDefinitionId     String
  scope               KpiTargetScope
  scopeKey            String
  country             Country?
  teamId              String?
  userId              String?
  targetValue         Decimal                @db.Decimal(14, 2)
  minValue            Decimal?               @db.Decimal(14, 2)
  maxValue            Decimal?               @db.Decimal(14, 2)
  evaluationDirection KpiEvaluationDirection
  kpiDefinition       KpiDefinition          @relation(fields: [kpiDefinitionId], references: [id], onDelete: Cascade)
  team                Team?                  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user                User?                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@unique([kpiDefinitionId, scopeKey])
  @@index([country])
  @@index([teamId])
  @@index([userId])
}

model KpiSnapshot {
  id              String        @id @default(cuid())
  userId          String
  kpiDefinitionId String
  periodStart     DateTime
  periodEnd       DateTime
  value           Decimal       @db.Decimal(14, 2)
  target          Decimal?      @db.Decimal(14, 2)
  source          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  kpiDefinition   KpiDefinition @relation(fields: [kpiDefinitionId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@unique([userId, kpiDefinitionId, periodStart, periodEnd])
  @@index([userId, periodEnd])
  @@index([periodStart, periodEnd])
}

model Intervention {
  id                   String                    @id @default(cuid())
  type                 InterventionType
  status               InterventionStatus        @default(CONCEPT)
  representativeId     String
  initiatorId          String
  ownerId              String
  teamId               String?
  country              Country
  title                String
  description          String?

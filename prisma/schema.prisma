model TrainingParticipant {
  id               String       @id @default(cuid())
  interventionId   String
  representativeId String
  intervention     Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  representative   User         @relation(fields: [representativeId], references: [id], onDelete: Cascade)

  @@unique([interventionId, representativeId])
  @@index([representativeId])
}

model TrainingDetail {
  id                      String       @id @default(cuid())
  interventionId          String       @unique
  theme                   String
  reason                  String       @db.Text
  desiredImprovement      String?      @db.Text
  targetAudience          String?
  kpi                     String?
  frameworkPhase          String?
  trainer                 String?
  result                  String?      @db.Text
  conclusion              String?      @db.Text
  followUpAction          String?      @db.Text
  createIndividualActions Boolean      @default(false)
  createGroupAction       Boolean      @default(false)
  actionDue               DateTime?
  sourceHelpRequestId     String?
  intervention            Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  createdAt               DateTime     @default(now())

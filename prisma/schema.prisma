generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  REPRESENTATIVE
  SALES_LEADER
  SALES_MANAGER
  SERVICE_OPERATOR
  COUNTRY_MANAGER
  GROUP_MANAGER
  ADMIN
  SUPER_ADMIN
}

enum Country {
  BE
  NL
  DE
}

enum Language {
  nl
  fr
  de
}

enum TeamLeaderType {
  PRIMARY
  EXTRA
}

enum RepresentativeLevel {
  STARTER
  SALES_EXECUTIVE
  PROFESSIONAL
  EXPERT
}

enum InterventionType {
  BEGELEIDING
  CONTACTMOMENT
  RETRAINING
  SALES_TRAINING
  HULPAANVRAAG
}

enum InterventionStatus {
  CONCEPT
  GEPLAND
  IN_UITVOERING
  WACHT_OP_VT_INPUT
  WACHT_OP_VT
  WACHT_OP_AKKOORD
  GEFINALISEERD
  AFGESLOTEN
  GESLOTEN
  VOLTOOID
  VERZONDEN_TER_AKKOORD
  AKKOORD_DOOR_VERTEGENWOORDIGER
  GEANNULEERD
  NIET_UITGEVOERD
}

enum ActionPointType {
  KPI
  VAARDIGHEID
  GEDRAG
}

enum ActionPointStatus {
  OPEN
  NIEUW
  IN_UITVOERING
  AFGEROND
  BEHAALD
  NIET_BEHAALD
  GEANNULEERD
}

enum CoachingActionReviewStatus {
  PROPOSED
  APPROVED
  REJECTED
  ACTIVE
}

enum Priority {
  LOW
  NORMAL
  HIGH
}

enum KpiEvaluationDirection {
  HIGHER_IS_BETTER
  LOWER_IS_BETTER
  TARGET
}

enum KpiTargetScope {
  GLOBAL
  COUNTRY
  TEAM
  USER
  ROLE
}

enum CriterionType {
  KPI
  COAT_RACK
  GENERAL_EVALUATION
  PERSONALITY
  GENERAL_COACHING_SCORE
}

enum CriterionScopeType {
  GLOBAL
  COUNTRY
  TEAM
  USER
}

enum KpiValueType {
  NUMBER
  DECIMAL
  CURRENCY
  BOOLEAN
  SCORE
}

enum KpiPeriodType {
  DAY
  WEEK
  MONTH
  QUARTER
  YEAR
  CUSTOM
}

enum ActionScope {
  GLOBAL
  COUNTRY
  TEAM
  USER
}

enum ReflectionStatus {
  NIET_GESTART
  INGEDIEND
}

enum ApprovalStatus {
  GELEZEN_AKKOORD
  GELEZEN_NIET_AKKOORD
}

enum HelpRequestStatus {
  NIEUW
  OPEN
  IN_BEHANDELING
  VERVOLGACTIE_GEPLAND
  BEGELEIDING
  CONTACTMOMENT
  RETRAINING
  SALESTRAINING
  GESLOTEN
  INGETROKKEN
  AFGESLOTEN
  GEANNULEERD
}

model User {
  id                       String                      @id @default(cuid())
  firstName                String
  lastName                 String
  email                    String                      @unique
  mobile                   String?
  avatarUrl                String?
  branchNumber             String?
  representativeId         String?                     @unique
  entraId                  String?                     @unique
  microsoftEmail           String?
  lastLoginAt              DateTime?
  passwordHash             String?
  role                     Role
  country                  Country
  language                 Language                    @default(nl)
  active                   Boolean                     @default(true)
  representativeLevel      RepresentativeLevel         @default(STARTER)
  teamSupervisor           Boolean                     @default(false)
  teamId                   String?
  levelId                  String?
  team                     Team?                       @relation("TeamMembers", fields: [teamId], references: [id])
  level                    Level?                      @relation(fields: [levelId], references: [id])
  primaryTeams             Team[]                      @relation("PrimaryLeader")
  teamLeaderships          TeamLeader[]
  representedItems         Intervention[]              @relation("RepresentativeInterventions")
  initiatedItems           Intervention[]              @relation("InitiatedInterventions")
  ownedItems               Intervention[]              @relation("OwnedInterventions")
  kpiSnapshots             KpiSnapshot[]
  kpiTargetOverrides       KpiTargetOverride[]
  scopedKpiDefinitions     KpiDefinition[]             @relation("KpiDefinitionUser")
  createdKpiDefinitions    KpiDefinition[]             @relation("KpiDefinitionCreatedBy")
  updatedKpiDefinitions    KpiDefinition[]             @relation("KpiDefinitionUpdatedBy")
  kpiTargets               KpiTarget[]                 @relation("KpiTargetUser")
  createdKpiTargets        KpiTarget[]                 @relation("KpiTargetCreatedBy")
  updatedKpiTargets        KpiTarget[]                 @relation("KpiTargetUpdatedBy")
  actionPoints             ActionPoint[]               @relation("RepresentativeActions")
  ownedActionPoints        ActionPoint[]               @relation("OwnedActions")
  closedActionPoints       ActionPoint[]               @relation("ClosedActionPoints")
  reflections              Reflection[]
  approvals                Approval[]
  requestedHelp            HelpRequest[]               @relation("HelpRequester")
  receivedHelp             HelpRequest[]               @relation("HelpRepresentative")
  responsibleHelpRequests   HelpRequest[]               @relation("HelpResponsible")
  helpRequestAnswers        HelpRequestAnswer[]         @relation("HelpAnswerAuthor")
  productAnalyses          ProductAnalysis[]
  auditLogs                AuditLog[]
  microsoftAuthToken       MicrosoftAuthToken?
  createdCriteria          PersonalCoachingCriterion[] @relation("CreatedPersonalCriteria")
  representativeCriteria   PersonalCoachingCriterion[] @relation("RepresentativePersonalCriteria")
  permissions              UserPermission[]
  loginAliases             UserLoginAlias[]
  loginSessions            UserLoginSession[]
  trainingParticipants     TrainingParticipant[]
  actionAssignments        ActionPointAssignment[]
  closedActionAssignments  ActionPointAssignment[]      @relation("ClosedActionPointAssignments")
  interventionParticipants InterventionParticipant[]
  scopedActionDefinitions   ActionDefinition[]        @relation("ActionDefinitionUser")
  createdActionDefinitions  ActionDefinition[]        @relation("ActionDefinitionCreatedBy")
  updatedActionDefinitions  ActionDefinition[]        @relation("ActionDefinitionUpdatedBy")
  actionTargetOverrides     ActionTargetOverride[]
  criterionScopeLinks       CriterionScopeLink[]      @relation("CriterionScopeLinkUser")
  coachingActions           CoachingAction[]
  coachingChangeLogs        CoachingChangeLog[]
  representativeLevelHistory RepresentativeLevelHistory[]
  countryAccess             UserCountryAccess[]
  createdAt                DateTime                    @default(now())
  updatedAt                DateTime                    @updatedAt

  @@index([country, role])
  @@index([teamId])
  @@index([role, representativeLevel])
}

model RepresentativeLevelHistory {
  id             String              @id @default(cuid())
  userId         String
  oldValue       RepresentativeLevel?
  newValue       RepresentativeLevel
  changedById    String?
  changedAt      DateTime            @default(now())
  reason         String?             @db.Text
  migrationKey   String?             @unique
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, changedAt])
  @@index([changedById])
}

model UserCountryAccess {
  id        String   @id @default(cuid())
  userId    String
  country   Country
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, country])
  @@index([country])
}

model MicrosoftAuthToken {
  id                    String   @id @default(cuid())
  userId                String   @unique
  accessTokenEncrypted  String   @db.LongText
  refreshTokenEncrypted String?  @db.LongText
  expiresAt             DateTime
  scopes                String   @db.VarChar(512)
  lastError             String?  @db.Text
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([expiresAt])
}

model UserLoginAlias {
  id        String   @id @default(cuid())
  userId    String
  email     String   @unique
  provider  String   @default("microsoft-entra-id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model UserLoginSession {
  id              String    @id @default(cuid())
  userId          String
  requestKey      String    @unique
  sessionId       String    @unique
  loginAt         DateTime  @default(now())
  logoutAt        DateTime?
  lastActivityAt  DateTime  @default(now())
  expiresAt       DateTime
  durationSeconds Int       @default(0)
  provider        String
  email           String?
  ipAddress       String?
  userAgent       String?   @db.Text
  browser         String?
  operatingSystem String?
  deviceType      String?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId, loginAt])
  @@index([userId, provider])
  @@index([userId, lastActivityAt])
}

model Team {
  id               String                      @id @default(cuid())
  name             String
  country          Country
  primaryLeaderId  String?
  active           Boolean                     @default(true)
  primaryLeader    User?                       @relation("PrimaryLeader", fields: [primaryLeaderId], references: [id], onDelete: SetNull)
  members          User[]                      @relation("TeamMembers")
  leaders          TeamLeader[]
  personalCriteria PersonalCoachingCriterion[]
  kpiTargetOverrides KpiTargetOverride[]
  kpiDefinitions     KpiDefinition[]             @relation("KpiDefinitionTeam")
  kpiTargets         KpiTarget[]                 @relation("KpiTargetTeam")
  actionDefinitions ActionDefinition[]
  actionTargetOverrides ActionTargetOverride[]
  criterionScopeLinks CriterionScopeLink[]       @relation("CriterionScopeLinkTeam")
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt

  @@unique([country, name])
}

model TeamLeader {
  id     String         @id @default(cuid())
  teamId String
  userId String
  type   TeamLeaderType
  team   Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  label       String
  group       String
  description String?          @db.Text
  roleGrants  RolePermission[]
  userGrants  UserPermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model RolePermission {
  id           String     @id @default(cuid())
  role         Role
  permissionId String
  enabled      Boolean    @default(true)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@index([permissionId])
}

model RoleConfiguration {
  id        String   @id @default(cuid())
  role      Role     @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
}

model UserPermission {
  id           String     @id @default(cuid())
  userId       String
  permissionId String
  enabled      Boolean
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([permissionId])
}

model Level {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  color       String
  active      Boolean  @default(true)
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model KpiDefinition {
  id                  String                 @id @default(cuid())
  code                String                 @unique
  name                String
  description         String
  categoryId          String?                @map("category_id")
  typeId              String?                @map("type_id")
  targetTypeId        String?                @map("target_type_id")
  country             Country?
  teamId              String?                @map("target_team_id")
  userId              String?                @map("target_user_id")
  targetRole          Role?                  @map("target_role")
  active              Boolean                @default(true)
  unit                String
  targetValue         Decimal                @default(0) @db.Decimal(14, 2)
  minValue            Decimal?               @db.Decimal(14, 2)
  maxValue            Decimal?               @db.Decimal(14, 2)
  weight              Decimal?               @db.Decimal(8, 2)
  countsForReporting  Boolean                @default(true) @map("counts_for_reporting")
  countsForPerformanceCircle Boolean         @default(true) @map("counts_for_performance_circle")
  sortOrder           Int                    @default(0) @map("sort_order")
  validFrom           DateTime               @default(now()) @map("valid_from")
  validUntil          DateTime?              @map("valid_until")
  createdById         String?                @map("created_by_user_id")
  updatedById         String?                @map("updated_by_user_id")
  evaluationDirection KpiEvaluationDirection @default(HIGHER_IS_BETTER)
  category            KpiCategory?           @relation(fields: [categoryId], references: [id])
  type                KpiType?               @relation(fields: [typeId], references: [id])
  targetType          KpiTargetType?         @relation(fields: [targetTypeId], references: [id])
  team                Team?                  @relation("KpiDefinitionTeam", fields: [teamId], references: [id], onDelete: Cascade)
  user                User?                  @relation("KpiDefinitionUser", fields: [userId], references: [id], onDelete: Cascade)
  createdBy           User?                  @relation("KpiDefinitionCreatedBy", fields: [createdById], references: [id])
  updatedBy           User?                  @relation("KpiDefinitionUpdatedBy", fields: [updatedById], references: [id])
  snapshots           KpiSnapshot[]
  actionPoints        ActionPoint[]
  targetOverrides     KpiTargetOverride[]
  targets             KpiTarget[]
  criterionScopeLinks CriterionScopeLink[]       @relation("CriterionScopeLinkKpi")
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@index([categoryId])
  @@index([typeId])
  @@index([targetTypeId])
  @@index([country])
  @@index([teamId])
  @@index([userId])
  @@index([active, sortOrder])
}

model KpiCategory {
  id             String          @id @default(cuid())
  code           String          @unique
  name           String
  description    String?         @db.Text
  isActive       Boolean         @default(true) @map("is_active")
  sortOrder      Int             @default(0) @map("sort_order")
  kpiDefinitions KpiDefinition[]
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("kpi_categories")
}

model KpiType {
  id             String          @id @default(cuid())
  code           String          @unique
  name           String
  description    String?         @db.Text
  valueType      KpiValueType    @map("value_type")
  isActive       Boolean         @default(true) @map("is_active")
  sortOrder      Int             @default(0) @map("sort_order")
  kpiDefinitions KpiDefinition[]
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("kpi_types")
}

model KpiTargetType {
  id             String          @id @default(cuid())
  code           KpiTargetScope  @unique
  name           String
  description    String?         @db.Text
  isActive       Boolean         @default(true) @map("is_active")
  sortOrder      Int             @default(0) @map("sort_order")
  kpiDefinitions KpiDefinition[]
  kpiTargets     KpiTarget[]
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@index([isActive, sortOrder])
  @@map("kpi_target_types")
}

model KpiTarget {
  id              String          @id @default(cuid())
  kpiDefinitionId String          @map("kpi_definition_id")
  targetTypeId    String          @map("target_type_id")
  scope           KpiTargetScope
  scopeKey        String          @map("scope_key")
  country         Country?
  teamId          String?         @map("team_id")
  userId          String?         @map("user_id")
  role            Role?
  periodType      KpiPeriodType   @map("period_type")
  periodStart     DateTime        @map("period_start")
  periodEnd       DateTime        @map("period_end")
  targetValue     Decimal         @db.Decimal(14, 2) @map("target_value")
  active          Boolean         @default(true)
  createdById     String?         @map("created_by_user_id")
  updatedById     String?         @map("updated_by_user_id")
  kpiDefinition   KpiDefinition   @relation(fields: [kpiDefinitionId], references: [id], onDelete: Cascade)
  targetType      KpiTargetType   @relation(fields: [targetTypeId], references: [id])
  team            Team?           @relation("KpiTargetTeam", fields: [teamId], references: [id], onDelete: Cascade)
  user            User?           @relation("KpiTargetUser", fields: [userId], references: [id], onDelete: Cascade)
  createdBy       User?           @relation("KpiTargetCreatedBy", fields: [createdById], references: [id])
  updatedBy       User?           @relation("KpiTargetUpdatedBy", fields: [updatedById], references: [id])
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@unique([kpiDefinitionId, scopeKey, periodType, periodStart, periodEnd])
  @@index([kpiDefinitionId, active])
  @@index([targetTypeId])
  @@index([scope, scopeKey])
  @@index([country])
  @@index([teamId])
  @@index([userId])
  @@index([role])
  @@index([periodStart, periodEnd])
  @@map("kpi_targets")
}

model KpiTargetOverride {
  id                  String                 @id @default(cuid())
  kpiDefinitionId     String
  scope               KpiTargetScope
  scopeKey            String
  country             Country?
  teamId              String?
  userId              String?
  targetValue         Decimal                @db.Decimal(14, 2)
  minValue            Decimal?               @db.Decimal(14, 2)
  maxValue            Decimal?               @db.Decimal(14, 2)
  evaluationDirection KpiEvaluationDirection
  kpiDefinition       KpiDefinition          @relation(fields: [kpiDefinitionId], references: [id], onDelete: Cascade)
  team                Team?                  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user                User?                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@unique([kpiDefinitionId, scopeKey])
  @@index([country])
  @@index([teamId])
  @@index([userId])
}

model KpiSnapshot {
  id              String        @id @default(cuid())
  userId          String
  kpiDefinitionId String
  periodStart     DateTime
  periodEnd       DateTime
  value           Decimal       @db.Decimal(14, 2)
  target          Decimal?      @db.Decimal(14, 2)
  source          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  kpiDefinition   KpiDefinition @relation(fields: [kpiDefinitionId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@unique([userId, kpiDefinitionId, periodStart, periodEnd])
  @@index([userId, periodEnd])
  @@index([periodStart, periodEnd])
}

model Intervention {
  id                   String                    @id @default(cuid())
  type                 InterventionType
  status               InterventionStatus        @default(CONCEPT)
  representativeId     String
  initiatorId          String
  ownerId              String
  teamId               String?
  country              Country
  title                String
  description          String?
  plannedAt            DateTime?
  startTime            String?
  endTime              String?
  notifyRepresentative Boolean                   @default(false)
  notifyCoachedRepresentative Boolean            @default(false)
  notifyCoachedTeamLeaders Boolean               @default(false)
  notifyExecutorTeamLeaders Boolean              @default(false)
  notifyCoachedLeaderIntent Boolean              @default(false)
  notifyExecutorLeaderIntent Boolean             @default(false)
  peerCoach            Boolean                   @default(false)
  teamDeviation        Boolean                   @default(false)
  countryDeviation     Boolean                   @default(false)
  deviationReason      String?                   @db.Text
  deviationRecordedById String?
  deviationRecordedAt  DateTime?
  startedAt            DateTime?
  actualStartedAt      DateTime?
  completedAt          DateTime?
  finalizedAt          DateTime?
  executionDeadlineAt  DateTime?
  approvalDeadlineAt   DateTime?
  finalApprovalDeadlineAt DateTime?
  performerAccessExpiresAt DateTime?
  lateCompletion       Boolean                   @default(false)
  lateCompletionReason String?                   @db.Text
  administrativelyClosedAt DateTime?
  administrativelyClosedById String?
  administrativeCloseReason String?              @db.Text
  copiedFromInterventionId String?
  historicAccessSettings String?                 @db.LongText
  sentForApprovalAt    DateTime?
  sentForApprovalById  String?
  approvedByRepAt      DateTime?
  approvedByRepId      String?
  deletedAt            DateTime?
  outlookEventId       String?
  outlookICalUId       String?
  outlookSyncStatus    OutlookSyncStatus         @default(NOT_SYNCED)
  lastSyncedAt         DateTime?
  syncError            String?                   @db.Text
  representative       User                      @relation("RepresentativeInterventions", fields: [representativeId], references: [id])
  initiator            User                      @relation("InitiatedInterventions", fields: [initiatorId], references: [id])
  owner                User                      @relation("OwnedInterventions", fields: [ownerId], references: [id])
  focuses              InterventionFocus[]
  scores               Score[]
  actionPoints         ActionPoint[]
  reflection           Reflection?
  approval             Approval?
  criterionSnapshots   CoachingCriterionSnapshot[]
  helpRequest          HelpRequest?
  contactMoment        ContactMomentDetail?
  coachingDetail       CoachingDetail?
  trainingDetail       TrainingDetail?
  participants         InterventionParticipant[]
  trainingParticipants TrainingParticipant[]
  coachingActions      CoachingAction[]
  coachingChangeLogs   CoachingChangeLog[]
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  @@index([representativeId, type])
  @@index([country, status])
  @@index([teamId])
  @@index([type, status, country, updatedAt])
  @@index([plannedAt])
  @@index([status, plannedAt])
  @@index([outlookEventId])
  @@index([ownerId, peerCoach])
  @@index([executionDeadlineAt])
  @@index([performerAccessExpiresAt])
  @@index([copiedFromInterventionId])
}

enum OutlookSyncStatus {
  NOT_SYNCED
  SYNCED
  ERROR
}

model ContactMomentDetail {
  id                   String       @id @default(cuid())
  interventionId       String       @unique
  reason               String
  subject              String?
  contactType          String?
  location             String?
  internalNotes        String?      @db.Text
  reportedProblems     String?      @db.Text
  leaderThemes         String       @db.LongText
  representativeKpis   String       @db.LongText
  representativeThemes String       @db.LongText
  discussedThemes      String       @db.LongText
  conclusion           String?      @db.Text
  reportHtml           String?      @db.LongText
  finalSnapshot        String?      @db.LongText
  photosJson           String?      @db.LongText
  sharedAt             DateTime?
  sharedById           String?
  closedReason         String?      @db.Text
  closedAt             DateTime?
  closedById           String?
  previousStatus       InterventionStatus?
  sourceHelpRequestId  String?
  intervention         Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@index([sharedAt])
  @@index([closedAt])
}

model CoachingFocus {
  id               String                      @id @default(cuid())
  code             String                      @unique
  name             String
  active           Boolean                     @default(true)
  sortOrder        Int
  criteria         CoachingCriterion[]
  personalCriteria PersonalCoachingCriterion[]
  interventions    InterventionFocus[]
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
}

model CoachingCriterion {
  id        String        @id @default(cuid())
  focusId   String
  name      String
  active    Boolean       @default(true)
  sortOrder Int
  focus     CoachingFocus @relation(fields: [focusId], references: [id], onDelete: Cascade)
  scores    Score[]
  criterionScopeLinks CriterionScopeLink[] @relation("CriterionScopeLinkCoatRack")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([focusId, name])
}

model ConfigurableCriterion {
  id             String               @id @default(cuid())
  type           CriterionType
  code           String               @unique
  title          String
  description    String?              @db.Text
  section        String?
  answerType     String               @default("SCORE_0_5")
  scoreType      String               @default("SCORE")
  minScore       Int                  @default(0)
  maxScore       Int                  @default(5)
  weight         Decimal?             @db.Decimal(8, 2)
  targetValue    Decimal?             @db.Decimal(14, 2)
  required       Boolean              @default(false)
  active         Boolean              @default(true)
  createdById    String?
  updatedById    String?
  scopeLinks     CriterionScopeLink[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([type, active])
}

model PersonalCoachingCriterion {
  id               String         @id @default(cuid())
  title            String
  description      String         @db.Text
  focusId          String?
  focusName        String
  representativeId String
  createdByUserId  String
  teamId           String
  country          Country
  active           Boolean        @default(true)
  focus            CoachingFocus? @relation(fields: [focusId], references: [id], onDelete: SetNull)
  representative   User           @relation("RepresentativePersonalCriteria", fields: [representativeId], references: [id], onDelete: Cascade)
  createdBy        User           @relation("CreatedPersonalCriteria", fields: [createdByUserId], references: [id])
  team             Team           @relation(fields: [teamId], references: [id])
  scores           Score[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([representativeId, title, active])
  @@index([teamId])
  @@index([country])
}

model InterventionFocus {
  id             String        @id @default(cuid())
  interventionId String
  focusId        String
  intervention   Intervention  @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  focus          CoachingFocus @relation(fields: [focusId], references: [id])

  @@unique([interventionId, focusId])
}

model InterventionParticipant {
  id               String       @id @default(cuid())
  interventionId   String
  representativeId String
  intervention     Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  representative   User         @relation(fields: [representativeId], references: [id], onDelete: Cascade)

  @@unique([interventionId, representativeId])
  @@index([representativeId])
}

model Score {
  id                  String                     @id @default(cuid())
  interventionId      String
  criterionId         String?
  personalCriterionId String?
  criterionSnapshotId String?
  category            String?
  label               String?
  score               Int?
  notApplicable       Boolean                    @default(false)
  comment             String?                    @db.Text
  previousScore       Int?
  intervention        Intervention               @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  criterion           CoachingCriterion?         @relation(fields: [criterionId], references: [id])
  personalCriterion   PersonalCoachingCriterion? @relation(fields: [personalCriterionId], references: [id])
  criterionSnapshot   CoachingCriterionSnapshot? @relation(fields: [criterionSnapshotId], references: [id])

  @@unique([interventionId, criterionId])
  @@index([personalCriterionId])
  @@index([criterionSnapshotId])
  @@index([interventionId, category])
}

model CriterionScopeLink {
  id                      String                 @id @default(cuid())
  criterionType           CriterionType
  criterionKey            String
  kpiDefinitionId         String?
  coachingCriterionId     String?
  configurableCriterionId String?
  scopeType               CriterionScopeType
  scopeKey                String
  country                 Country?
  teamId                  String?
  userId                  String?
  sortOrder               Int                    @default(0)
  createdById             String?
  updatedById             String?
  kpiDefinition           KpiDefinition?         @relation("CriterionScopeLinkKpi", fields: [kpiDefinitionId], references: [id], onDelete: Cascade)
  coachingCriterion       CoachingCriterion?     @relation("CriterionScopeLinkCoatRack", fields: [coachingCriterionId], references: [id], onDelete: Cascade)
  configurableCriterion   ConfigurableCriterion? @relation(fields: [configurableCriterionId], references: [id], onDelete: Cascade)
  team                    Team?                  @relation("CriterionScopeLinkTeam", fields: [teamId], references: [id], onDelete: SetNull)
  user                    User?                  @relation("CriterionScopeLinkUser", fields: [userId], references: [id], onDelete: SetNull)
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt

  @@unique([criterionKey, scopeType, scopeKey])
  @@index([criterionType])
  @@index([scopeType, scopeKey])
  @@index([kpiDefinitionId])
  @@index([coachingCriterionId])
  @@index([configurableCriterionId])
  @@index([country])
  @@index([teamId])
  @@index([userId])
}

model CoachingCriterionSnapshot {
  id                    String             @id @default(cuid())
  interventionId        String
  criterionType         CriterionType
  sourceCriterionId     String
  sourceCriterionKey    String
  sourceScopeLinkId     String?
  title                 String
  description           String?            @db.Text
  focusName             String?
  section               String?
  answerType            String
  scoreType             String
  minScore              Int?
  maxScore              Int?
  weight                Decimal?           @db.Decimal(8, 2)
  targetValue           Decimal?           @db.Decimal(14, 2)
  required              Boolean            @default(false)
  appliedScopeType      CriterionScopeType
  appliedScopeKey       String
  appliedScopeLabel     String
  sortOrder             Int                @default(0)
  snapshotVersion       Int                @default(1)
  intervention          Intervention       @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  scores                Score[]
  createdAt             DateTime           @default(now())

  @@unique([interventionId, criterionType, sourceCriterionId])
  @@index([interventionId, criterionType])
  @@index([sourceCriterionKey])
  @@index([appliedScopeType, appliedScopeKey])
}

model CoachingDetail {
  id                       String                @id @default(cuid())
  interventionId           String                @unique
  arrivalTime              String?
  departureTime            String?
  kilometers               Decimal?              @db.Decimal(14, 2)
  area                     String?
  sector                   String?
  groupAttentionPoints     String                @db.LongText
  individualAttentionPoint String?               @db.Text
  intervention             Intervention          @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  appointments             CoachingAppointment[]
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
}

model CoachingAppointment {

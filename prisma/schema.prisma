  isNew              Boolean           @default(false)
  reviewStatus       CoachingActionReviewStatus @default(PROPOSED)
  originalTitle      String?           @db.Text
  originalDescription String?          @db.Text
  originalTipsAndTricks String?        @db.LongText
  rejectionReason    String?           @db.Text
  reviewComment      String?           @db.Text
  reviewedById       String?
  reviewedAt         DateTime?
  activatedAt        DateTime?
  intervention       Intervention      @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  actionDefinition   ActionDefinition? @relation(fields: [actionDefinitionId], references: [id], onDelete: SetNull)
  user               User              @relation(fields: [userId], references: [id])
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@unique([interventionId, actionDefinitionId])
  @@index([userId])
  @@index([reviewStatus])
  @@index([reviewedById])
}


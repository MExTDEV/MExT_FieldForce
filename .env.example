DATABASE_URL="mysql://mext_user:replace-with-password@database-host:3306/mext_fieldforce"
DEPLOYMENT_ENV="local"
APP_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
PORT="3000"
SEED_ALLOW_DESTRUCTIVE="false"
# Controlled live test mode only. Keep both values false for normal production.
SALESDAY_PRODUCTION_MOCK_MODE="false"
# Required together with the explicit live-system-mock command on a non-test database.
SALESDAY_UAT_SEED_ALLOW_NON_TEST_DATABASE="false"

AUTH_SECRET="replace-with-at-least-32-random-characters"
NEXT_PUBLIC_AUTH_MODE="credentials"
NEXT_PUBLIC_ENABLE_DEMO_USER_SWITCHER="false"
AUTH_MICROSOFT_ENTRA_ID_ID=""
AUTH_MICROSOFT_ENTRA_ID_SECRET=""
AUTH_MICROSOFT_ENTRA_ID_ISSUER="https://login.microsoftonline.com/replace-with-tenant-id/v2.0"
AUTH_MICROSOFT_ENTRA_TENANT_ID=""
# Delegated Graph sync uses User.Read + Calendars.ReadWrite for the signed-in user only.
OUTLOOK_TIME_ZONE="Romance Standard Time"
# Private uploaded Contactmoment photos are stored below this root.
# In production this directory must be persistent and included in server backups.
FIELD_FORCE_UPLOAD_ROOT="storage/uploads"
# Server-side Microsoft profile photo sync uses app-only Graph access.
PROFILE_PHOTO_SYNC_CONCURRENCY="4"

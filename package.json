{
  "name": "mext-fieldforce",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "prisma generate",
    "build": "next build",
    "start": "node server.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:workflow": "tsx scripts/test-workflow.ts",
    "test:smart-coaching": "tsx scripts/test-smart-coaching.ts",
    "test:performance": "tsx scripts/test-performance-data.ts",
    "test:pdf-report": "tsx scripts/test-professional-coaching-pdf.ts",
    "test:personal-criteria": "tsx scripts/test-personal-criteria.ts",
    "test:modules": "tsx scripts/test-modules.ts",
    "test:data-access": "tsx scripts/test-data-access.ts",
    "test:coaching-visibility": "tsx scripts/test-coaching-visibility.ts",
    "test:menu-rights": "tsx scripts/test-menu-rights.ts",
    "test:coaching-db": "tsx scripts/test-coaching-database.ts",
    "test:auth-session": "tsx scripts/test-auth-session.ts",
    "test:login-history": "tsx scripts/test-login-history.ts",
    "test:api-persistence": "tsx scripts/test-api-persistence.ts",
    "test:db-verification": "tsx scripts/verify-step10-database.ts",
    "env:check": "tsx scripts/validate-environment.ts",
    "env:check:production": "tsx scripts/validate-environment.ts --production",
    "health:check": "tsx scripts/check-health.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:config": "tsx prisma/seed.ts",
    "db:seed:dev": "tsx prisma/seed.ts --dev-demo",
    "auth:set-password": "tsx scripts/set-user-password.ts",
    "deploy:prepare": "npm run env:check:production && npm run db:generate && npm run db:migrate:deploy && npm run db:seed:config && npm run build",
    "start:production": "npm run env:check:production && node server.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.468.0",
    "next": "15.5.19",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "svg2pdf.js": "^2.7.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.27.0",
    "eslint-config-next": "15.5.19",
    "postcss": "^8.5.3",
    "prisma": "^6.9.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
